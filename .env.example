# Google Books API Key
# Get one at: https://console.cloud.google.com/apis/library/books.googleapis.com
GOOGLE_API_KEY=your_google_books_api_key_here

# Random secret string used to encrypt session data — change this!
# Generate one e.g. with: python -c "import secrets; print(secrets.token_hex(32))"
STORAGE_SECRET=change_me_to_a_long_random_string

# Timezone (optional, defaults to UTC if not set)
TZ=Europe/Berlin

# Port (optional, defaults to 8080)
# PORT=8080
